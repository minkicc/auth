db:
  # Optional: mysql / sqlite. If omitted and the MySQL fields below are empty,
  # MKAuth defaults to SQLite at data/mkauth.sqlite3.
  # driver: "sqlite"
  # sqlite_path: "data/mkauth.sqlite3"
  user: "root"
  password: "YOUR_DB_PASSWORD"
  host: "YOUR_DB_HOST"
  port: 3306
  database: "mkauth"
  charset: "utf8mb4"

redis:
  addr: "YOUR_REDIS_HOST:6379"
  password: "YOUR_REDIS_PASSWORD"
  db: 0

oidc:
  enabled: true
  issuer: "https://auth.example.com"
  key_id: "mkauth-oidc-v1"
  private_key_file: ""
  private_key_pem: ""
  code_ttl_seconds: 300
  access_token_ttl_seconds: 900
  id_token_ttl_seconds: 900
  clients:
    - client_id: "demo-spa"
      public: true
      require_pkce: true
      redirect_uris:
        - "http://127.0.0.1:3000/callback"
      scopes:
        - "openid"
        - "profile"
        - "email"
    - client_id: "demo-backend"
      client_secret: "CHANGE_ME"
      public: false
      require_pkce: true
      redirect_uris:
        - "http://127.0.0.1:8080/auth/callback"
      scopes:
        - "openid"
        - "profile"
        - "email"

iam:
  # Optional static bootstrap. You can also create enterprise OIDC/SAML
  # providers later from the admin console under Organizations -> Enterprise Login.
  enterprise_oidc:
    - slug: "acme"
      name: "Acme Workforce"
      organization_id: "org_acme000000000000"
      # Optional multi-IdP policy. Lower priority wins.
      priority: 10
      is_default: true
      auto_redirect: true
      issuer: "https://idp.example.com"
      client_id: "YOUR_ENTERPRISE_OIDC_CLIENT_ID"
      client_secret: "YOUR_ENTERPRISE_OIDC_CLIENT_SECRET"
      redirect_uri: "https://auth.example.com/api/enterprise/oidc/acme/callback"
      scopes:
        - "openid"
        - "profile"
        - "email"
  enterprise_saml:
    - slug: "acme-saml"
      name: "Acme SAML"
      organization_id: "org_acme000000000000"
      # Optional multi-IdP policy. Lower priority wins.
      priority: 20
      is_default: false
      auto_redirect: false
      idp_metadata_url: "https://idp.example.com/metadata"
      # idp_metadata_xml: "<EntityDescriptor ...>...</EntityDescriptor>"
      entity_id: "https://auth.example.com/api/enterprise/saml/acme-saml/metadata"
      acs_url: "https://auth.example.com/api/enterprise/saml/acme-saml/acs"
      name_id_format: "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress"
      email_attribute: "email"
      username_attribute: "preferred_username"
      display_name_attribute: "displayName"
      allow_idp_initiated: false
      default_redirect_uri: "https://app.example.com/login/callback"
  scim_inbound:
    - enabled: false
      slug: "acme-scim"
      name: "Acme SCIM"
      organization_id: "org_acme000000000000"
      # Prefer bearer_token_hash in production. You can generate a bcrypt hash
      # with: cd tools && go run hashpwd.go -password "YOUR_SCIM_TOKEN"
      bearer_token_hash: "$2a$10$..."
      # bearer_token is convenient for local testing, but should not be used
      # in production config files.
      bearer_token: ""

plugins:
  enabled: false
  # Local plugin packages are loaded from these directories.
  # The admin plugin page installs ZIP packages into the first directory.
  directories:
    - "plugins"
  enabled_plugins: []
  disabled_plugins: []
  # Optional: restrict local plugin manifests to this permission allowlist.
  # Leave empty to allow every currently supported plugin permission.
  allowed_permissions:
    - "hook:post_authenticate"
    - "hook:before_token_issue"
    - "hook:before_userinfo"
    - "network:http_action"
  # When enabled, local plugins must provide a valid mkauth-plugin.sig file.
  require_signature: false
  # Keep false in production unless remote plugin catalogs/packages are hosted
  # on a private network you explicitly trust.
  allow_private_networks: false
  # Optional: restrict which hosts can serve remote catalogs and plugin ZIP files.
  # Supports exact hosts, host:port, .example.com, and *.example.com.
  allowed_catalog_hosts:
    - "plugins.example.com"
  allowed_download_hosts:
    - "plugins.example.com"
    - "downloads.example.com"
  # Optional: restrict outbound HTTP Action endpoints declared by plugins.
  allowed_action_hosts:
    - "actions.example.com"
  trusted_signers:
    - id: "mkauth-dev"
      algorithm: "ed25519"
      public_key: "BASE64_ED25519_PUBLIC_KEY"
  catalogs:
    - id: "official"
      name: "Official Plugin Catalog"
      url: "https://plugins.example.com/mkauth/catalog.yaml"
      enabled: false
  # Optional: centrally configured remote HTTP actions.
  # Local flow_action plugins can also carry their own http_action block in
  # mkauth-plugin.yaml, so they do not need to be repeated here.
  http_actions:
    - id: "claims-enricher"
      name: "Claims Enricher"
      enabled: false
      events:
        - "before_token_issue"
        - "before_userinfo"
        - "post_authenticate"
      url: "https://actions.example.com/mkauth"
      secret: "YOUR_ACTION_BEARER_SECRET"
      timeout_ms: 3000
      fail_open: false

storage:
  # provider: minio / s3 / r2 / oss
  provider: "minio"
  endpoint: "YOUR_MINIO_OR_R2_ENDPOINT"
  region: "YOUR_REGION_OR_AUTO_FOR_R2"
  accessKeyID: "YOUR_ACCESS_KEY_ID"
  secretAccessKey: "YOUR_SECRET_ACCESS_KEY"
  stsAccessKeyID: "YOUR_STS_ACCESS_KEY_ID"
  stsSecretAccessKey: "YOUR_STS_SECRET_ACCESS_KEY"
  attatchBucket: "attatch"

storage_public_url:
  attatch: "YOUR_PUBLIC_URL"

auth:
  enabled_providers:
    - "weixin"
    - "weixin_mini"
  google:
    client_id: "YOUR_GOOGLE_CLIENT_ID"
    client_secret: "YOUR_GOOGLE_CLIENT_SECRET"
    redirect_url: "YOUR_GOOGLE_REDIRECT_URL"
    scopes:
      - "https://www.googleapis.com/auth/userinfo.email"
      - "https://www.googleapis.com/auth/userinfo.profile"
  weixin:
    app_id: "YOUR_WEIXIN_APP_ID"
    app_secret: "YOUR_WEIXIN_APP_SECRET"
    redirect_url: "YOUR_WEIXIN_REDIRECT_URL"
    domain_verify_token: "YOUR_WEIXIN_DOMAIN_VERIFY_TOKEN"
  weixin_mini:
    app_id: "YOUR_WEIXIN_MINI_APP_ID"
    app_secret: "YOUR_WEIXIN_MINI_APP_SECRET"
    grant_type: "authorization_code"
  sms:
    provider: "aliyun"
    access_key: "YOUR_SMS_ACCESS_KEY"
    secret_key: "YOUR_SMS_SECRET_KEY"
    sign_name: "验证码"
    template_id: "YOUR_SMS_TEMPLATE_ID"
    region: "cn-hangzhou"

  smtp:
    host: "YOUR_SMTP_HOST"
    port: 80
    username: "YOUR_SMTP_USERNAME"
    password: "YOUR_SMTP_PASSWORD"
    from: "YOUR_SMTP_FROM"

auth_admin:
  enabled: true
  secret_key: "YOUR_ADMIN_SECRET_KEY"
  accounts:
    - username: "admin"
      password: "YOUR_ADMIN_PASSWORD_HASH"
      roles:
        - "super_admin"
    - username: "operator"
      password: "YOUR_OPERATOR_PASSWORD_HASH"
      roles:
        - "user_manager"
  allowed_ips:
    - "127.0.0.1"
    - "::1"
  require_tls: false
  session_ttl: 30
  login_timeout: 60

auth_trusted_clients:
  - client_id: "kcserver"
    client_secret: "YOUR_TRUSTED_CLIENT_SECRET"
    allowed_ips:
      - "*"
    scopes:
      - "read:users" 
